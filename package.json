{
  "name": "emerald",
  "private": true,
  "scripts": {
    "lint": "eslint .",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "build": "pnpm -r run build",
    "dev:docs": "pnpm --filter @emerald/docs dev",
    "dev:workspace": "pnpm --filter @emerald/workspace dev",
    "storybook": "storybook dev -p 6100",
    "storybook:build": "storybook build",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@storybook/react-vite": "9.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "9.1.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.4"
  },
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "msw": {
    "workerDirectory": [
      "apps\\docs\\public",
      "apps\\workspace\\public"
    ]
  }
}