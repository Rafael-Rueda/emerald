# =========================================================
# EMERALD — Production environment file
# Copied to `.env` by scripts/setup-production.sh
# NEVER commit the resulting .env file (it is gitignored).
# =========================================================
# Sections:
#   1. Domain / TLS
#   2. Database (Postgres + pgvector)
#   3. JWT keys (RS256, base64)
#   4. Google OAuth 2.0
#   5. Embedding provider (pluggable: voyage | openai | google | ollama)
#   6. GCP Cloud Storage
#   7. ISR revalidation
#   8. CORS
#   9. Logging / runtime
# =========================================================


# ---------------------------------------------------------
# 1. Domain / TLS  (required, manual)
# ---------------------------------------------------------
# Root apex domain. Subdomains api./docs./app. will be derived
# for Caddy vhosts and CORS/OAuth callbacks.
DOMAIN=CHANGE_ME_example.com
# Email used by Let's Encrypt / ZeroSSL when Caddy provisions TLS.
ACME_EMAIL=CHANGE_ME_admin@example.com


# ---------------------------------------------------------
# 2. Database  (auto-generated by setup script)
# ---------------------------------------------------------
POSTGRES_USER=emerald
POSTGRES_DB=emerald
POSTGRES_PASSWORD=CHANGE_ME_autogenerated
# Host resolves to the compose service name on emerald_net.
DATABASE_URL=postgresql://emerald:CHANGE_ME_autogenerated@postgres:5432/emerald?schema=public


# ---------------------------------------------------------
# 3. JWT keys  (auto-generated base64 RS256 by setup script)
# ---------------------------------------------------------
# Produced via: openssl genrsa 2048 | base64 -w0
JWT_PRIVATE_KEY=CHANGE_ME_autogenerated
JWT_PUBLIC_KEY=CHANGE_ME_autogenerated


# ---------------------------------------------------------
# 4. Google OAuth 2.0  (required, manual)
# ---------------------------------------------------------
# Create an OAuth client at:
#   https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_OAUTH2_REDIRECT_URL below.
GOOGLE_OAUTH2_CLIENT_ID=CHANGE_ME
GOOGLE_OAUTH2_CLIENT_SECRET=CHANGE_ME
# Auto-derived from DOMAIN by setup script.
GOOGLE_OAUTH2_REDIRECT_URL=https://api.CHANGE_ME_example.com/auth/google/callback


# ---------------------------------------------------------
# 5. Embedding provider (pluggable)
# ---------------------------------------------------------
# Options: voyage | openai | google | ollama
EMBEDDING_PROVIDER=voyage
# Vector dimension. MUST match pgvector column size configured in the schema.
# Per-provider constraints are enforced at startup in apps/api/src/env/env.ts.
#   voyage: 256 | 512 | 1024 | 2048
#   openai text-embedding-3-small: 512 | 768 | 1024 | 1536
#   openai text-embedding-3-large: 256 | 1024 | 3072
#   google text-embedding-004: 128 | 256 | 512 | 768
#   ollama nomic-embed-text: 768 | mxbai-embed-large: 1024 | all-minilm: 384
EMBEDDING_DIMENSION=512

# --- Voyage AI (required when EMBEDDING_PROVIDER=voyage) ---
# Get an API key at https://www.voyageai.com/
VOYAGE_API_KEY=CHANGE_ME
VOYAGE_MODEL=voyage-3-lite

# --- OpenAI (required when EMBEDDING_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Google Vertex AI (required when EMBEDDING_PROVIDER=google) ---
# GOOGLE_PROJECT_ID=my-gcp-project
# Path inside the api container (mount via compose secrets volume if distinct
# from the Storage service account).
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-key.json
# GOOGLE_VERTEX_LOCATION=us-central1
# GOOGLE_EMBEDDING_MODEL=text-embedding-004

# --- Ollama (required when EMBEDDING_PROVIDER=ollama) ---
# Self-hosted, no API key. Run Ollama on the same VPS (systemd / docker run)
# or point at a remote host. NOT bundled in this compose file — GPU-heavy
# workloads are better orchestrated separately.
#   nomic-embed-text        -> 768
#   mxbai-embed-large       -> 1024
#   all-minilm              -> 384
#   bge-m3                  -> 1024
#   snowflake-arctic-embed  -> 1024
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text


# ---------------------------------------------------------
# 6. GCP Cloud Storage  (required, manual)
# ---------------------------------------------------------
# Bucket must grant Storage Object Admin to the service account whose JSON
# key is mounted at secrets/gcp-key.json (chmod 600, gitignored).
GCP_BUCKET_NAME=CHANGE_ME
# Path inside the api container (mounted via compose volume).
GCP_KEY_FILE_PATH=/run/secrets/gcp-key.json
MAX_FILE_SIZE_MB=10


# ---------------------------------------------------------
# 7. ISR revalidation  (auto-generated shared secret)
# ---------------------------------------------------------
# Shared secret between api <-> docs for Next.js ISR revalidation calls.
DOCS_REVALIDATE_SECRET=CHANGE_ME_autogenerated


# ---------------------------------------------------------
# 8. CORS  (auto-derived from DOMAIN by setup script)
# ---------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://docs.CHANGE_ME_example.com,https://app.CHANGE_ME_example.com


# ---------------------------------------------------------
# 9. Logging / runtime
# ---------------------------------------------------------
# error | warn | log | debug | verbose
LOG_LEVEL=log
