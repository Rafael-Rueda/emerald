# API
NODE_ENV="development"
PORT=3333

# DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/emerald_db?schema=public"

# CRYPTOGRAPHY (generate with scripts/generate-jwt.ps1 or openssl)
JWT_PRIVATE_KEY="YOUR_BASE64_ENCODED_PRIVATE_KEY_HERE"
JWT_PUBLIC_KEY="YOUR_BASE64_ENCODED_PUBLIC_KEY_HERE"

# GOOGLE OAUTH 2.0
GOOGLE_OAUTH2_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID_HERE"
GOOGLE_OAUTH2_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET_HERE"
GOOGLE_OAUTH2_REDIRECT_URL="http://localhost:3333/auth/google/callback"

# DOCS ISR REVALIDATION
DOCS_APP_URL="http://localhost:3100"
DOCS_REVALIDATE_SECRET="your-dev-revalidation-secret"

# GCP STORAGE (for file/image uploads)
GCP_BUCKET_NAME="your-gcp-bucket-name"
GCP_KEY_FILE_PATH="./gcp-service-account.json"
MAX_FILE_SIZE_MB=10

# EMBEDDING PROVIDERS (pluggable: voyage | openai | google | ollama)
EMBEDDING_PROVIDER="voyage"
EMBEDDING_DIMENSION="512"

# Voyage AI (default provider)
VOYAGE_API_KEY="YOUR_VOYAGE_API_KEY_HERE"
VOYAGE_MODEL="voyage-3-lite"

# OpenAI (optional alternative)
OPENAI_API_KEY=""
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Google Vertex AI (optional alternative)
GOOGLE_PROJECT_ID=""
GOOGLE_APPLICATION_CREDENTIALS=""
GOOGLE_VERTEX_LOCATION="us-central1"
GOOGLE_EMBEDDING_MODEL="text-embedding-004"

# Ollama (optional self-hosted alternative; must be running separately)
OLLAMA_BASE_URL=""
OLLAMA_EMBEDDING_MODEL=""

# CORS
CORS_ALLOWED_ORIGINS="http://localhost:3100,http://localhost:3101"

# LOG LEVEL
LOG_LEVEL="log"