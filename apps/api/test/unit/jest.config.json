{
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "../..",
    "roots": ["<rootDir>/src/domain", "<rootDir>/src/http/mcp"],
    "testEnvironment": "node",
    "testRegex": "src/.*/unit/.*\\.spec\\.ts$",
    "transform": {
        "^.+\\.ts$": [
            "ts-jest",
            {
                "tsconfig": "<rootDir>/tsconfig.json",
                "useESM": false
            }
        ]
    },
    "moduleNameMapper": {
        "^@/(.*)$": "<rootDir>/src/$1",
        "^(\\.{1,2}/.*)\\.js$": "$1"
    }
}
