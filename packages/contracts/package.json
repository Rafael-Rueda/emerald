{
  "name": "@emerald/contracts",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts",
      "require": "./dist/*.js",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --module commonjs --moduleResolution node",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@emerald/configs": "workspace:*",
    "typescript": "^5.7.3"
  }
}
